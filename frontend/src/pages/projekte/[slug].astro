---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetaList from '../../components/ui/MetaList.astro';
import PageIntro from '../../components/ui/PageIntro.astro';

export async function getStaticPaths() {
  const entries = await getCollection('references');
  return entries
    .filter((entry) => typeof entry.body === 'string' && entry.body.trim().length > 0)
    .map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} | Referenz | Tappauf ZT`}
  description={`${entry.data.title}: ${entry.data.details}${entry.data.category ? `, ${entry.data.category}` : ''}.`}
  ogImage={entry.data.heroImage}
  ogType="article"
>
  <article class="reference-detail py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <PageIntro eyebrow="Referenz" title={entry.data.title} text={entry.data.details} />

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <aside class="space-y-6">
          {entry.data.heroImage && (
            <div class="reference-detail__media overflow-hidden rounded-[2rem] border" data-reveal>
              <Image src={entry.data.heroImage} alt={entry.data.title} class="h-full w-full object-cover" />
            </div>
          )}
          <MetaList
            title="Projektdaten"
            items={[
              { label: 'Details', value: entry.data.details },
              { label: 'Auftraggeber', value: entry.data.client },
              { label: 'Kategorie', value: entry.data.category },
              { label: 'Jahr', value: entry.data.year ? String(entry.data.year) : undefined },
            ]}
          />
        </aside>

        <main data-reveal>
          <div class="reference-detail__prose prose prose-lg max-w-none">
            <Content />
          </div>
        </main>
      </div>
    </div>
  </article>
</BaseLayout>
