---
// Dateipfad: frontend/src/components/ReferenceCard.astro
const { project } = Astro.props;
const { title, details, category, year } = project.data;
const hasDetails = typeof project.body === 'string' && project.body.trim().length > 0;
const categoryLabels = {
  hochbau: 'Hochbau',
  tiefbau: 'Tiefbau',
  industrie: 'Industriebau',
  bruecken: 'Brueckenbau',
  sonderprojekte: 'Sonderprojekte',
} as const;
const categoryLabel = categoryLabels[category] ?? category;
---

<article class="reference-card group flex h-full flex-col rounded-[2rem] border p-7 backdrop-blur transition">
  <div class="reference-card__meta mb-4 flex items-center gap-3 font-mono text-[10px] uppercase tracking-[0.2em]">
    <span class={`reference-card__category reference-card__category--${category}`}>
      {categoryLabel}
    </span>
    {year && <span>{year}</span>}
  </div>
  <h3 class="reference-card__title text-2xl font-semibold tracking-[-0.02em]">
    {hasDetails ? <a href={`/projekte/${project.id}`}>{title}</a> : title}
  </h3>
  {hasDetails && (
    <p class="reference-card__text mt-4 text-sm leading-7">
      {details}
    </p>
  )}
  {hasDetails && (
    <div class="reference-card__cta mt-auto pt-6 text-xs font-bold uppercase tracking-[0.2em]">
      Details ansehen →
    </div>
  )}
</article>
