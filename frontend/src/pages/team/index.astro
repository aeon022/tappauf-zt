---
// Dateipfad: frontend/src/pages/team/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const team = await getCollection('team');
---
<BaseLayout title="Unser Team | Tappauf ZT">
  <main class="py-32 max-w-7xl mx-auto px-6">
    <h1 class="text-6xl font-black italic uppercase tracking-tighter mb-20 text-slate-900">Expertise<br/><span class="text-blue-600">im Team.</span></h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-24">
      {team.map(member => (
        <div class="group">
          <div class="aspect-[4/5] bg-slate-100 mb-8 overflow-hidden relative">
            {member.data.image && <img src={member.data.image} alt={member.data.name} class="object-cover w-full h-full grayscale group-hover:grayscale-0 transition-all duration-500" />}
            <div class="absolute inset-0 border-m border-white/20 group-hover:border-blue-600/50 transition-colors"></div>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-1">{member.data.name}</h3>
          <p class="text-sm font-mono text-blue-600 uppercase tracking-widest mb-6">{member.data.role}</p>
          <a href={`mailto:${member.data.email}`} class="text-xs font-bold border-b-2 border-slate-200 pb-1 hover:border-blue-600 transition-all uppercase tracking-widest">Kontaktieren</a>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>