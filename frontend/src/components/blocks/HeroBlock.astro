---
import { Image } from 'astro:assets';
import MetricCard from '../ui/MetricCard.astro';

interface Metric {
  value: string;
  label: string;
}

interface Props {
  eyebrow: string;
  headline: string;
  text: string;
  image?: any;
  imageAlt?: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
  metrics: Metric[];
}

const {
  eyebrow,
  headline,
  text,
  image,
  imageAlt,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  metrics,
} = Astro.props;

const specialHeadline = headline?.trim() === 'Tragwerke fuer komplexe Anforderungen.';
---

<section class="relative isolate overflow-hidden bg-slate-900 text-white">
  <div class="hero-field" aria-hidden="true">
    <div class="hero-field__mesh"></div>
    <div class="hero-field__line hero-field__line--one"></div>
    <div class="hero-field__line hero-field__line--two"></div>
    <div class="hero-field__line hero-field__line--three"></div>
    <div class="hero-field__orb hero-field__orb--one"></div>
    <div class="hero-field__orb hero-field__orb--two"></div>
    <div class="hero-field__glow"></div>
  </div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.35),_transparent_32%),radial-gradient(circle_at_80%_20%,_rgba(148,163,184,0.16),_transparent_28%),linear-gradient(135deg,_#020617_0%,_#0f172a_60%,_#111827_100%)]"></div>
  <div class="relative mx-auto grid max-w-7xl items-center gap-14 px-6 py-20 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-28">
    <div data-reveal>
      <p class="mb-6 text-xs font-semibold uppercase tracking-[0.35em] text-blue-300">{eyebrow}</p>
      <h1 class="max-w-4xl font-display text-5xl font-semibold tracking-[-0.03em] text-white sm:text-6xl lg:text-7xl">
        {specialHeadline ? (
          <>
            <span class="flex max-w-[12ch] items-baseline gap-x-3 leading-[0.88] sm:max-w-none">
              <span class="text-white">Tragwerke</span>
              <span class="text-[0.42em] font-normal tracking-[-0.02em] text-slate-300">fuer</span>
            </span>
            <span class="mt-3 flex max-w-[14ch] items-baseline gap-x-3 leading-[0.92] sm:max-w-none">
              <span class="text-[0.42em] font-normal tracking-[-0.02em] text-slate-300">komplexe</span>
              <span class="text-[0.98em] font-semibold tracking-[-0.04em] text-white">Anforderungen.</span>
            </span>
          </>
        ) : (
          headline
        )}
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-slate-300">{text}</p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href={primaryHref} class="rounded-full bg-blue-500 px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-blue-400">{primaryLabel}</a>
        <a href={secondaryHref} class="rounded-full border border-white/20 px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-white transition hover:border-white/50 hover:bg-white/5">{secondaryLabel}</a>
      </div>
    </div>

    <div class="grid gap-6" data-reveal>
      {image && (
        <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 shadow-[0_30px_80px_rgba(2,6,23,0.45)]">
          <Image
            src={image}
            alt={imageAlt || headline}
            class="aspect-[4/3] w-full object-cover"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      )}
      <div class="grid gap-5 sm:grid-cols-2">
        {metrics.map((metric) => <MetricCard value={metric.value} label={metric.label} />)}
      </div>
    </div>
  </div>
</section>
