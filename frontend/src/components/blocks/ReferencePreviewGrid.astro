---
interface ReferenceEntry {
  data: {
    title: string;
    details: string;
  };
}

interface Props {
  references: ReferenceEntry[];
}

const { references } = Astro.props;
---

<div class="mt-14 grid gap-6 md:grid-cols-2">
  {references.map((reference, index) => (
    <article class="relative rounded-[2rem] border border-white/10 bg-white/5 p-7 backdrop-blur" data-reveal>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-blue-300">Ref {String(index + 1).padStart(2, '0')}</p>
      <h3 class="mt-4 text-2xl font-semibold tracking-[-0.02em] text-white">{reference.data.title}</h3>
      <p class="mt-3 text-sm leading-7 text-slate-300">{reference.data.details}</p>
    </article>
  ))}
</div>
