---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';

const settings = await getEntry('settings', 'global');
const phoneHref = `tel:${(settings?.data.phone || '').replace(/[^+\d]/g, '')}`;
---

<BaseLayout title="Impressum | Tappauf ZT" description="Impressum der Tappauf ZT GmbH mit Unternehmens- und Kontaktdaten." noindex={true}>
  <main class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <PageIntro
        eyebrow="Rechtliches"
        title="Impressum"
        text="Angaben gemäß den Informationspflichten für den Webauftritt der Tappauf ZT GmbH."
      />

      <section class="mt-12 overflow-hidden rounded-[2.5rem] border border-slate-200 bg-white shadow-[0_20px_70px_rgba(15,23,42,0.08)]" data-reveal>
        <div class="grid gap-0 lg:grid-cols-[1.05fr_0.95fr]">
          <div class="bg-[linear-gradient(160deg,_rgba(248,250,252,0.98),_rgba(241,245,249,0.92))] px-8 py-10 sm:px-12 sm:py-12 lg:px-14 lg:py-14">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-blue-600">Unternehmen</p>
            <h2 class="mt-3 font-display text-3xl font-semibold tracking-[-0.03em] text-slate-950 sm:text-[2.4rem]">{settings?.data.siteTitle}</h2>
            <p class="mt-6 max-w-md whitespace-pre-line text-base leading-8 text-slate-700">{settings?.data.address}</p>

            <div class="mt-10 space-y-5 border-t border-slate-200 pt-8 text-base leading-8 text-slate-700">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">E-Mail</p>
                <a href={`mailto:${settings?.data.email}`} class="mt-2 inline-block font-semibold text-blue-600 transition hover:text-slate-950">{settings?.data.email}</a>
              </div>

              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Telefon</p>
                <a href={phoneHref} class="mt-2 inline-block font-semibold text-blue-600 transition hover:text-slate-950">{settings?.data.phone}</a>
              </div>
            </div>
          </div>

          <div class="px-8 py-10 sm:px-12 sm:py-12 lg:px-16 lg:py-14 xl:px-20">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Rechtliche Angaben</p>
            <div class="mt-8 grid gap-6">
              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-7 sm:p-8">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Firmenbuchnummer</p>
                <p class="mt-3 text-lg font-semibold text-slate-950">FN 600142 m</p>
              </div>

              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-7 sm:p-8">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">UID-Nummer</p>
                <p class="mt-3 text-lg font-semibold text-slate-950">ATU 79188549</p>
              </div>

              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-7 sm:p-8">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Verantwortlich für den Inhalt</p>
                <div class="mt-3 whitespace-pre-line text-base leading-8 text-slate-700">
                  {`Tappauf ZT GmbH\n${settings?.data.address || ''}`}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
