---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetaList from '../../components/ui/MetaList.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import { withBase } from '../../lib/withBase';

export async function getStaticPaths() {
  const entries = await getCollection('jobs');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const jobDescription = [entry.data.summary, entry.body]
  .filter(Boolean)
  .join(' ')
  .replace(/[#>*_`-]/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();
const jobPostingData = {
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: entry.data.title,
  description: jobDescription,
  employmentType: entry.data.employmentType,
  jobLocation: entry.data.location
    ? {
        '@type': 'Place',
        address: {
          '@type': 'PostalAddress',
          addressLocality: entry.data.location,
          addressCountry: 'AT',
        },
      }
    : undefined,
  hiringOrganization: {
    '@type': 'Organization',
    name: 'Tappauf ZT GmbH',
    sameAs: 'https://www.tappauf-zt.at',
  },
  applicantLocationRequirements: {
    '@type': 'Country',
    name: 'AT',
  },
  directApply: true,
};
const seoBase = Astro.site ?? Astro.url;
const jobStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL(withBase('/'), seoBase).toString() },
      { '@type': 'ListItem', position: 2, name: 'Jobs', item: new URL(withBase('/jobs'), seoBase).toString() },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: new URL(withBase(`/jobs/${entry.id}`), seoBase).toString() },
    ],
  },
  jobPostingData,
];
---

<BaseLayout
  title={`${entry.data.title} | Jobs in Graz | Tappauf ZT`}
  description={entry.data.summary || `Offene Position ${entry.data.title} bei Tappauf ZT in Graz.`}
  structuredData={jobStructuredData}
  noindex={entry.data.status === 'archiviert'}
>
  <article class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <PageIntro eyebrow="Jobs" title={entry.data.title} text={entry.data.summary} />

      <div class="mt-12 grid gap-10 lg:grid-cols-[0.72fr_1.28fr]">
        <MetaList
          title="Rahmendaten"
          items={[
            { label: 'Status', value: entry.data.status },
            { label: 'Standort', value: entry.data.location },
            { label: 'Arbeitszeit', value: entry.data.workload },
            { label: 'Anstellungsart', value: entry.data.employmentType },
            { label: 'Bewerbung', value: entry.data.applyEmail, href: entry.data.applyEmail ? `mailto:${entry.data.applyEmail}` : undefined },
          ]}
        />

        <main data-reveal>
          <div class="jobs-content prose prose-slate prose-lg max-w-none">
            <Content />
          </div>
        </main>
      </div>
    </div>
  </article>
</BaseLayout>
