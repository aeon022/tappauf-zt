---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReferenceCard from '../../components/blocks/ReferenceCard.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import { withBase } from '../../lib/withBase';

const allProjects = await getCollection('references');
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);
const seoBase = Astro.site ?? Astro.url;
const categoryLabels = {
  alle: 'Alle',
  hochbau: 'Hochbau',
  tiefbau: 'Tiefbau',
  industrie: 'Industriebau',
  bruecken: 'Brueckenbau',
  sonderprojekte: 'Sonderprojekte',
} as const;
const filterOptions = Object.entries(categoryLabels).map(([value, label]) => ({
  value,
  label,
  count: value === 'alle' ? sortedProjects.length : sortedProjects.filter((project) => project.data.category === value).length,
}));
const commandPaletteShortcut = 'Strg + K';
const referencesPageUrl = new URL(withBase('/projekte'), seoBase).toString();
---

<BaseLayout
  title="Referenzen im Hochbau, Industriebau und Brueckenbau | Tappauf ZT"
  description="Ausgewaehlte Referenzen aus Hochbau, Industriebau, Brueckenbau und Spezialaufgaben mit Fokus auf Tragwerksplanung und Baudynamik."
  structuredData={[
    {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: 'Referenzen',
      description: 'Ausgewaehlte Referenzen aus Hochbau, Industriebau, Brueckenbau und Spezialaufgaben mit Fokus auf Tragwerksplanung und Baudynamik.',
      url: referencesPageUrl,
    },
    {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: 'Referenzen',
      itemListElement: sortedProjects.map((project, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: project.data.title,
        url: new URL(withBase(`/projekte/${project.id}`), seoBase).toString(),
      })),
    },
  ]}
>
  <main class="references-index bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <PageIntro
        eyebrow="Portfolio"
        title="Referenzen"
        text="Ausgewaehlte Projekte aus Hochbau, Industriebau, Brueckenbau und Spezialaufgaben mit Fokus auf Tragwerksplanung und Baudynamik."
      />

      <section class="mt-14 overflow-hidden rounded-[2.5rem] border border-slate-200/80 bg-white/88 shadow-[0_24px_80px_rgba(15,23,42,0.08)] backdrop-blur">
        <div class="grid gap-10 px-7 py-8 lg:grid-cols-[1.1fr_0.9fr] lg:px-10 lg:py-10">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.32em] text-blue-600">Projektübersicht</p>
            <h2 class="mt-4 max-w-[14ch] font-display text-[2.2rem] font-semibold leading-[0.98] tracking-[-0.03em] text-slate-950 sm:text-[2.65rem]">
              Ausgewählte Tragwerke, klar sortierbar.
            </h2>
            <p class="mt-5 max-w-2xl text-base leading-8 text-slate-700">
              Ausgewählte Projekte aus Hochbau, Industriebau, Brückenbau und Sonderaufgaben. Die Übersicht zeigt realisierte Arbeiten aus unterschiedlichen Maßstäben und Anwendungsbereichen der Tragwerksplanung und Baudynamik.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-2">
            <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50/90 p-5">
              <p class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Projekte</p>
              <p class="mt-4 font-display text-4xl font-semibold tracking-[-0.04em] text-slate-950">{sortedProjects.length}</p>
            </div>
            <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50/90 p-5">
              <p class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Kategorien</p>
              <p class="mt-4 font-display text-4xl font-semibold tracking-[-0.04em] text-slate-950">{filterOptions.length - 1}</p>
            </div>
            <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50/90 p-5 sm:col-span-3 lg:col-span-2">
              <p class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Filter</p>
              <p class="mt-3 text-sm leading-7 text-slate-600">Filtert die Projektliste nach Fachbereich.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="mt-10" data-reference-filter-root>
        <div class="reference-search-shell rounded-[2rem] border border-slate-200/80 bg-white/92 p-5 shadow-[0_24px_80px_rgba(15,23,42,0.06)] backdrop-blur sm:p-6">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-2xl">
              <p class="text-[10px] font-mono uppercase tracking-[0.24em] text-slate-500">Suche</p>
              <p class="mt-2 text-sm leading-7 text-slate-600">
                Freitextsuche ueber Projekttitel, Auftraggeber, Kategorie und Jahr. Die globale Command Palette erschliesst zusaetzlich Inhalte, Kontakt und Bedienoptionen.
              </p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row">
              <label class="reference-search-input flex min-w-0 items-center gap-3 rounded-full border border-slate-200 bg-slate-50/90 px-4 py-3 text-sm text-slate-700 shadow-sm">
                <span class="text-slate-400" aria-hidden="true">/</span>
                <input
                  type="search"
                  name="q"
                  placeholder="Titel, Auftraggeber, Kategorie oder Jahr"
                  class="min-w-0 flex-1 bg-transparent text-sm text-slate-900 outline-none placeholder:text-slate-400"
                  autocomplete="off"
                  spellcheck="false"
                  data-reference-search-input
                />
              </label>
              <button
                type="button"
                class="reference-command-trigger inline-flex items-center justify-between gap-4 rounded-full border border-slate-200 bg-white px-4 py-3 text-left text-sm text-slate-700 shadow-sm transition hover:border-blue-300 hover:text-blue-600"
                data-site-command-open
              >
                <span>Command Palette</span>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">{commandPaletteShortcut}</span>
              </button>
            </div>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          {filterOptions.map((option) => (
            <button
              type="button"
              class:list={[
                'reference-filter-chip inline-flex items-center gap-3 rounded-full border px-4 py-2.5 text-xs font-semibold uppercase tracking-[0.18em] transition',
                option.value === 'alle'
                  ? 'reference-filter-chip--active border-slate-900 bg-slate-900 text-white'
                  : 'border-slate-200 bg-white text-slate-700 hover:border-blue-300 hover:text-blue-600',
              ]}
              data-reference-filter={option.value}
              aria-pressed={option.value === 'alle' ? 'true' : 'false'}
            >
              <span>{option.label}</span>
              <span class="rounded-full bg-black/10 px-2 py-1 text-[10px] leading-none">{option.count}</span>
            </button>
          ))}
        </div>

        <div class="mt-5 flex items-center justify-between gap-4 border-b border-slate-200 pb-4">
          <p class="text-xs font-mono uppercase tracking-[0.24em] text-slate-500">
            Ansicht: <span data-reference-filter-label>Alle</span>
          </p>
          <p class="text-xs font-mono uppercase tracking-[0.24em] text-slate-500">
            Sichtbar: <span data-reference-filter-count>{sortedProjects.length}</span>
          </p>
        </div>
      </section>

      <div class="mx-auto mt-10 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-2 2xl:grid-cols-3" data-reference-grid>
        {sortedProjects.map((project) => (
          <ReferenceCard project={project} />
        ))}
      </div>

      {sortedProjects.length === 0 && (
        <div class="rounded-xl border-2 border-dashed border-slate-300 py-20 text-center">
          <p class="font-mono text-slate-500">Keine Projekte in `src/content/references/entries` gefunden.</p>
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<script is:inline>
  const setupReferenceFilters = () => {
    const root = document.querySelector('[data-reference-filter-root]');
    if (!root || root.dataset.filterBound === 'true') return;

    const chips = Array.from(root.querySelectorAll('[data-reference-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-reference-card]'));
    const countNode = document.querySelector('[data-reference-filter-count]');
    const labelNode = document.querySelector('[data-reference-filter-label]');
    const searchInput = root.querySelector('[data-reference-search-input]');

    if (!chips.length || !cards.length) {
      root.dataset.filterBound = 'true';
      return;
    }

    let activeFilter = 'alle';
    let activeLabel = 'Alle';
    let searchTerm = '';

    const normalize = (value) => (value || '').trim().toLowerCase();
    const getLabelByValue = (value) =>
      chips.find((chip) => chip.dataset.referenceFilter === value)?.querySelector('span')?.textContent || 'Alle';

    const matchesSearch = (card, value) => {
      if (!value) return true;
      const haystack = card.dataset.search || '';
      return value.split(/\s+/).filter(Boolean).every((token) => haystack.includes(token));
    };

    const syncUrl = () => {
      const url = new URL(window.location.href);
      if (activeFilter && activeFilter !== 'alle') {
        url.searchParams.set('category', activeFilter);
      } else {
        url.searchParams.delete('category');
      }

      if (searchTerm) {
        url.searchParams.set('q', searchTerm);
      } else {
        url.searchParams.delete('q');
      }

      window.history.replaceState({}, '', url);
    };

    const applyFilter = (value, label, nextSearch = searchTerm) => {
      activeFilter = value;
      activeLabel = label;
      searchTerm = normalize(nextSearch);
      let visible = 0;

      cards.forEach((card) => {
        const matches = (value === 'alle' || card.dataset.category === value) && matchesSearch(card, searchTerm);
        card.toggleAttribute('hidden', !matches);
        card.classList.toggle('reference-card--hidden', !matches);
        if (matches) visible += 1;
      });

      chips.forEach((chip) => {
        const active = chip.dataset.referenceFilter === value;
        chip.classList.toggle('reference-filter-chip--active', active);
        chip.classList.toggle('border-slate-900', active);
        chip.classList.toggle('bg-slate-900', active);
        chip.classList.toggle('text-white', active);
        chip.classList.toggle('border-slate-200', !active);
        chip.classList.toggle('bg-white', !active);
        chip.classList.toggle('text-slate-700', !active);
        chip.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      if (countNode) countNode.textContent = String(visible);
      if (labelNode) labelNode.textContent = label;
      if (searchInput && searchInput.value !== searchTerm) searchInput.value = searchTerm;
      syncUrl();
    };

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        applyFilter(chip.dataset.referenceFilter || 'alle', chip.querySelector('span')?.textContent || 'Alle');
      });
    });

    searchInput?.addEventListener('input', () => {
      applyFilter(activeFilter, activeLabel, searchInput.value);
    });

    searchInput?.addEventListener('keydown', (event) => {
      if (event.ctrlKey && !event.metaKey && !event.altKey && event.key.toLowerCase() === 'k') {
        event.preventDefault();
        window.__tappaufOpenCommandPalette?.();
      }
    });

    const params = new URLSearchParams(window.location.search);
    const initialFilter = chips.some((chip) => chip.dataset.referenceFilter === params.get('category'))
      ? params.get('category')
      : 'alle';
    const initialSearch = params.get('q') || '';
    applyFilter(initialFilter, getLabelByValue(initialFilter), initialSearch);

    root.dataset.filterBound = 'true';
  };

  setupReferenceFilters();
  document.addEventListener('astro:page-load', setupReferenceFilters);
</script>
