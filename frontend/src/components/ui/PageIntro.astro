---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
  inverse?: boolean;
}

const { eyebrow, title, text, inverse = false } = Astro.props;
---

<header class="max-w-3xl" data-reveal>
  <p class:list={['text-xs font-semibold uppercase tracking-[0.35em]', inverse ? 'text-blue-300' : 'text-blue-600']}>{eyebrow}</p>
  <h1 class:list={['mt-4 font-display text-5xl font-semibold tracking-[-0.03em] sm:text-6xl', inverse ? 'text-white' : 'text-slate-950']}>{title}</h1>
  {text && <p class:list={['mt-6 text-lg leading-8', inverse ? 'text-slate-300' : 'text-slate-600']}>{text}</p>}
</header>
