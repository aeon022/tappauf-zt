---
// Dateipfad: frontend/src/components/blocks/DataCard.astro
interface Props {
  title: string;
  subtitle?: string;
  href: string;
  meta?: string;
  type?: 'service' | 'project' | 'job';
}
const { title, subtitle, href, meta, type = 'project' } = Astro.props;
---
<a href={href} class="group block border-l border-slate-200 pl-6 py-4 hover:border-blue-600 transition-all">
  <div class="flex items-center gap-3 mb-4">
    <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-blue-600 bg-blue-50 px-2 py-0.5">
      {type}
    </span>
    {meta && <span class="text-[10px] font-mono text-slate-400 uppercase tracking-widest">{meta}</span>}
  </div>
  <h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-tight">
    {title}
  </h3>
  {subtitle && <p class="mt-3 text-sm text-slate-500 line-clamp-2 leading-relaxed italic">{subtitle}</p>}
  <div class="mt-6 flex items-center text-[10px] font-bold uppercase tracking-[0.3em] text-slate-400 group-hover:text-blue-600">
    Details anzeigen <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
  </div>
</a>