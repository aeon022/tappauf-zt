---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="rounded-[1.75rem] border border-white/10 bg-white/6 p-7 backdrop-blur-md shadow-[0_18px_50px_rgba(2,6,23,0.22)]" data-reveal>
  <p class="text-4xl font-black text-white sm:text-5xl">{value}</p>
  <p class="mt-3 text-sm uppercase tracking-[0.22em] text-slate-300">{label}</p>
</div>
