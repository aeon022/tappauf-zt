---
// Dateipfad: frontend/src/layouts/BaseLayout.astro
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import { withBase } from '../lib/withBase';
import { hasReferenceContent } from '../lib/referenceContent';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string | { src: string; width?: number; height?: number };
  ogType?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, any> | Record<string, any>[];
}
const settings = await getEntry('settings', 'global');
const {
  title,
  description = settings?.data.metaDescription || "Tappauf ZT - Ingenieurbüro für Tragwerksplanung & Baudynamik",
  canonicalPath,
  ogImage,
  ogType = 'website',
  noindex = false,
  structuredData = [],
} = Astro.props;
const footerPhoneHref = `tel:${(settings?.data.phone || '').replace(/[^+\d]/g, '')}`;
const homeHref = withBase('/');
const leistungenHref = withBase('/leistungen');
const projekteHref = withBase('/projekte');
const publikationenHref = withBase('/publikationen');
const teamHref = withBase('/team');
const jobsHref = withBase('/jobs');
const kontaktHref = withBase('/kontakt');
const impressumHref = withBase('/impressum');
const datenschutzHref = withBase('/datenschutz');
const cookiePolicyHref = withBase('/cookie-richtlinien');
const faviconHref = withBase('/favicon.ico');
const faviconSvgHref = withBase('/favicon.svg');
const normalizePathname = (value: string) => {
  if (!value) return '/';
  return value !== '/' && value.endsWith('/') ? value.slice(0, -1) : value;
};
const currentPath = normalizePathname(Astro.url.pathname);
const isKeystaticRoute = currentPath === normalizePathname(withBase('/keystatic')) || currentPath.startsWith(`${normalizePathname(withBase('/keystatic'))}/`);
const [services, references, jobs, team, publications] = isKeystaticRoute
  ? [[], [], [], [], []]
  : await Promise.all([
      getCollection('services'),
      getCollection('references'),
      getCollection('jobs'),
      getCollection('team'),
      getCollection('publications'),
    ]);
const isCurrentPath = (href: string) => {
  const target = normalizePathname(href);
  return target === '/' ? currentPath === '/' : currentPath === target || currentPath.startsWith(`${target}/`);
};
const primaryNavLinks = [
  { href: homeHref, label: 'Home' },
  { href: leistungenHref, label: 'Leistungen' },
  { href: projekteHref, label: 'Referenzen' },
  { href: publikationenHref, label: 'Publikationen' },
  { href: teamHref, label: 'Team' },
  { href: jobsHref, label: 'Jobs' },
  { href: kontaktHref, label: 'Kontakt' },
].map((item) => ({ ...item, active: isCurrentPath(item.href) }));
const utilityNavLinks = [
  { href: impressumHref, label: 'Impressum' },
  { href: datenschutzHref, label: 'Datenschutz' },
  { href: cookiePolicyHref, label: 'Cookie-Richtlinien' },
].map((item) => ({ ...item, active: isCurrentPath(item.href) }));
const globalPageEntries = [
  {
    title: 'Home',
    description: 'Startseite und Ueberblick',
    type: 'Seite',
    section: 'Navigation',
    href: homeHref,
    search: 'home startseite ueberblick seite',
  },
  {
    title: 'Leistungen',
    description: 'Alle Leistungsfelder im Ueberblick',
    type: 'Seite',
    section: 'Navigation',
    href: leistungenHref,
    search: 'leistungen fachbereiche leistungsfelder service seite',
  },
  {
    title: 'Referenzen',
    description: 'Projektübersicht und Referenzen',
    type: 'Seite',
    section: 'Navigation',
    href: projekteHref,
    search: 'referenzen projekte projektuebersicht portfolio seite',
  },
  {
    title: 'Publikationen',
    description: 'Publikationsseite und Fachbeiträge',
    type: 'Seite',
    section: 'Navigation',
    href: publikationenHref,
    search: 'publikationen publikation fachbeiträge veroeffentlichungen seite',
  },
  {
    title: 'Team',
    description: 'Teamseite und Ansprechpartner',
    type: 'Seite',
    section: 'Navigation',
    href: teamHref,
    search: 'team mitarbeiter ansprechpartner seite',
  },
  {
    title: 'Jobs',
    description: 'Karriereseite und offene Stellen',
    type: 'Seite',
    section: 'Navigation',
    href: jobsHref,
    search: 'jobs karriere stellen offene positionen seite',
  },
  {
    title: 'Kontakt',
    description: 'Kontaktseite mit Adresse, E-Mail und Telefon',
    type: 'Seite',
    section: 'Navigation',
    href: kontaktHref,
    search: `kontakt kontaktseite anfrage email e-mail telefon adresse anfahrt ${settings?.data.email || ''} ${settings?.data.phone || ''}`.toLowerCase(),
  },
  {
    title: 'Impressum',
    description: 'Rechtliche Angaben',
    type: 'Seite',
    section: 'Rechtliches',
    href: impressumHref,
    search: 'impressum rechtliches seite',
  },
  {
    title: 'Datenschutz',
    description: 'Datenschutz und Privatsphäre',
    type: 'Seite',
    section: 'Rechtliches',
    href: datenschutzHref,
    search: 'datenschutz privacy privatsphaere seite',
  },
];
const globalCommandIndex = [
  ...globalPageEntries,
  ...services
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({
      title: entry.data.title,
      description: entry.data.summary,
      type: 'Leistung',
      section: 'Leistungen',
      href: withBase(`/leistungen/${entry.id}`),
      search: [entry.data.title, entry.data.summary, ...(entry.data.items || [])].filter(Boolean).join(' ').toLowerCase(),
    })),
  ...references
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({
      title: entry.data.title,
      description: [entry.data.client, entry.data.details, entry.data.year ? String(entry.data.year) : ''].filter(Boolean).join(' · '),
      type: 'Referenz',
      section: 'Referenzen',
      href: hasReferenceContent(entry.body) ? withBase(`/projekte/${entry.id}`) : projekteHref,
      search: [entry.data.title, entry.data.client, entry.data.details, entry.data.category, entry.data.year ? String(entry.data.year) : ''].filter(Boolean).join(' ').toLowerCase(),
    })),
  ...jobs
    .filter((entry) => entry.data.status === 'aktiv')
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({
      title: entry.data.title,
      description: entry.data.summary || entry.data.location || 'Offene Position',
      type: 'Job',
      section: 'Karriere',
      href: withBase(`/jobs/${entry.id}`),
      search: [entry.data.title, entry.data.summary, entry.data.location, entry.data.workload, entry.data.employmentType].filter(Boolean).join(' ').toLowerCase(),
    })),
  ...team
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({
      title: entry.data.name,
      description: [entry.data.role, entry.data.qualification].filter(Boolean).join(' · '),
      type: 'Team',
      section: 'Team',
      href: teamHref,
      search: [entry.data.name, entry.data.role, entry.data.qualification, entry.data.email].filter(Boolean).join(' ').toLowerCase(),
    })),
  ...publications
    .sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order)
    .slice(0, 20)
    .map((entry) => ({
      title: entry.data.title,
      description: [entry.data.year ? String(entry.data.year) : '', entry.data.citation].filter(Boolean).join(' · '),
      type: 'Publikation',
      section: 'Publikationen',
      href: publikationenHref,
      search: [entry.data.title, entry.data.citation, String(entry.data.year)].filter(Boolean).join(' ').toLowerCase(),
    })),
];
const socialLinks = [
  { label: 'Facebook', href: settings?.data.facebook },
  { label: 'X', href: settings?.data.x },
  { label: 'Instagram', href: settings?.data.instagram },
  { label: 'TikTok', href: settings?.data.tiktok },
  { label: 'LinkedIn', href: settings?.data.linkedin },
  { label: 'YouTube', href: settings?.data.youtube },
].filter((item) => item.href);
const seoBase = Astro.site ?? Astro.url;
const siteUrl = new URL(import.meta.env.BASE_URL, seoBase).toString();
const canonicalUrl = new URL(canonicalPath || Astro.url.pathname, seoBase).toString();
const brandImage = settings?.data.logo?.src ? new URL(settings.data.logo.src, seoBase).toString() : undefined;
const resolvedOgImage =
  typeof ogImage === 'string'
    ? new URL(ogImage, seoBase).toString()
    : ogImage?.src
      ? new URL(ogImage.src, seoBase).toString()
      : brandImage
        ? brandImage
        : undefined;
const ogImageWidth = typeof ogImage === 'object' ? ogImage.width : settings?.data.logo?.width;
const ogImageHeight = typeof ogImage === 'object' ? ogImage.height : settings?.data.logo?.height;
const organizationData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: settings?.data.siteTitle,
  url: siteUrl,
  logo: brandImage,
  image: brandImage,
  description: settings?.data.siteDescription,
  email: settings?.data.email,
  telephone: settings?.data.phone,
  address: settings?.data.address
    ? {
        '@type': 'PostalAddress',
        streetAddress: settings.data.address.split('\n')[0],
        addressLocality: 'Graz',
        postalCode: '8010',
        addressCountry: 'AT',
      }
    : undefined,
  sameAs: socialLinks.map((item) => item.href),
};
const websiteData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: settings?.data.siteTitle,
  url: siteUrl,
  inLanguage: 'de-AT',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${new URL(withBase('/projekte'), seoBase).toString()}?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
const pageData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonicalUrl,
  description,
  inLanguage: 'de-AT',
};
const extraStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const structuredDataPayload = [organizationData, websiteData, pageData, ...extraStructuredData].filter(Boolean);
const globalCommandIndexJson = JSON.stringify(globalCommandIndex);
const structuredDataJson = JSON.stringify(structuredDataPayload);
---
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="color-scheme" content="light dark" />
    <meta property="og:locale" content="de_AT" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={settings?.data.siteTitle || 'Tappauf ZT GmbH'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    {resolvedOgImage && <meta property="og:image:alt" content={title} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    <meta name="author" content={settings?.data.siteTitle || 'Tappauf ZT GmbH'} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" href={faviconHref} sizes="any" />
    <link rel="icon" href={faviconSvgHref} type="image/svg+xml" />
    <ClientRouter />
    <script type="application/ld+json" is:inline set:html={structuredDataJson}></script>
    <script is:inline>
      (() => {
        const key = 'tappauf-theme';
        const root = document.documentElement;

        const getPreferredTheme = () =>
          window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';

        const getStoredTheme = () => {
          try {
            return localStorage.getItem(key);
          } catch {
            return null;
          }
        };

        const applyTheme = (theme) => {
          root.dataset.theme = theme;
          root.classList.toggle('dark', theme === 'dark');
        };

        applyTheme(getStoredTheme() || getPreferredTheme());
      })();
    </script>
  </head>
  <body class="bg-white text-slate-900 antialiased font-sans selection:bg-blue-100">
    <div class="site-pattern" aria-hidden="true" transition:persist>
      <div class="site-pattern__grid"></div>
      <div class="site-pattern__pulse site-pattern__pulse--one"></div>
      <div class="site-pattern__pulse site-pattern__pulse--two"></div>
    </div>

    <nav class="sticky top-0 z-50 border-b border-slate-200 bg-white/80 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a href={homeHref} class="font-display text-xl font-semibold tracking-[-0.02em] uppercase group">
          {settings?.data.logo ? (
            <Image
              src={settings.data.logo}
              alt={settings?.data.logoAlt || settings?.data.siteTitle || 'Logo'}
              class="site-logo site-logo--header h-10 w-auto object-contain"
              loading="eager"
              decoding="async"
            />
          ) : (
            <>Tappauf<span class="text-blue-600 group-hover:text-slate-900 transition-colors">.ZT</span></>
          )}
        </a>
        <div class="hidden md:flex gap-10 text-[11px] font-bold uppercase tracking-[0.2em]">
          {primaryNavLinks.map((item) => (
            <a
              href={item.href}
              class:list={[
                'nav-link',
                item.active ? 'nav-link--active text-blue-600' : 'text-slate-900 hover:text-blue-600',
              ]}
              aria-current={item.active ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
        <div class="flex items-center gap-2 xl:gap-3">
          <button
            type="button"
            class="command-trigger hidden xl:inline-flex"
            data-site-command-open
            aria-label="Suche öffnen"
            title="Suche öffnen"
          >
            <span class="command-trigger__label">Suche</span>
            <span class="command-trigger__shortcut">Strg + K</span>
          </button>
          <button
            type="button"
            class="theme-toggle hidden sm:inline-flex"
            data-theme-toggle
            aria-label="Farbschema wechseln"
            title="Farbschema wechseln"
          >
            <span class="theme-toggle__icon" aria-hidden="true">◐</span>
            <span class="theme-toggle__label">Dark</span>
          </button>
          <button
            type="button"
            class="mobile-menu-toggle md:hidden"
            data-mobile-menu-open
            aria-label="Menü öffnen"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </nav>

    <div id="mobile-menu" class="mobile-menu" data-mobile-menu aria-hidden="true" hidden>
      <div class="mobile-menu__backdrop" data-mobile-menu-close></div>
      <div class="mobile-menu__panel">
        <div class="mobile-menu__top">
          <a href={homeHref} class="mobile-menu__brand" data-mobile-menu-link>
            {settings?.data.logo ? (
              <Image
                src={settings.data.logo}
                alt={settings?.data.logoAlt || settings?.data.siteTitle || 'Logo'}
                class="site-logo site-logo--header h-8 w-auto object-contain"
                loading="eager"
                decoding="async"
              />
            ) : (
              <span class="font-display text-lg font-semibold uppercase tracking-[-0.02em]">
                Tappauf<span class="text-blue-500">.ZT</span>
              </span>
            )}
          </a>
          <div class="flex items-center gap-3">
            <button
              type="button"
              class="command-trigger"
              data-site-command-open
              aria-label="Suche öffnen"
              title="Suche öffnen"
            >
              <span class="command-trigger__label">Suche</span>
              <span class="command-trigger__shortcut">Strg + K</span>
            </button>
            <button
              type="button"
              class="theme-toggle"
              data-theme-toggle
              aria-label="Farbschema wechseln"
              title="Farbschema wechseln"
            >
              <span class="theme-toggle__icon" aria-hidden="true">◐</span>
              <span class="theme-toggle__label">Dark</span>
            </button>
            <button
              type="button"
              class="mobile-menu-close"
              data-mobile-menu-close
              aria-label="Menü schließen"
            >
              <span></span>
              <span></span>
            </button>
          </div>
        </div>

        <div class="mobile-menu__body">
          <div class="mobile-menu__links">
            {primaryNavLinks.map((item) => (
              <a
                href={item.href}
                class:list={['mobile-menu__link', item.active && 'mobile-menu__link--active']}
                aria-current={item.active ? 'page' : undefined}
                data-mobile-menu-link
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="page-shell" transition:name="page-shell">
      <slot />
    </div>

    <div class="reference-command-dialog" data-site-command-dialog aria-hidden="true" hidden>
      <div class="reference-command-panel">
        <div class="reference-command-head">
          <div class="flex items-center gap-4">
            {settings?.data.logo ? (
              <Image
                src={settings.data.logo}
                alt={settings?.data.logoAlt || settings?.data.siteTitle || 'Logo'}
                class="site-logo site-logo--header h-8 w-auto object-contain"
                loading="eager"
                decoding="async"
              />
            ) : (
              <span class="font-display text-lg font-semibold uppercase tracking-[-0.02em]">
                Tappauf<span class="text-blue-600">.ZT</span>
              </span>
            )}
            <div>
              <p class="text-[10px] font-mono uppercase tracking-[0.24em] text-slate-500">Command Palette</p>
              <p class="mt-1 text-sm text-slate-600">Direkter Zugriff auf Inhalte, Kontakt und Bedienoptionen.</p>
            </div>
          </div>
          <button type="button" class="reference-command-close" data-site-command-close aria-label="Suche schließen">Esc</button>
        </div>
        <label class="reference-command-input">
          <span class="text-slate-400" aria-hidden="true">&gt;</span>
          <input
            type="search"
            placeholder="Suche nach Leistungen, Referenzen, Jobs, Team oder Publikationen"
            autocomplete="off"
            spellcheck="false"
            data-site-command-input
          />
        </label>
        <p class="mt-4 text-xs leading-6 text-slate-500">
          Mit `Strg + K` öffnet die Palette. Suche startet nach Eingabe. `Enter` öffnet den ersten Treffer, `Esc` schließt die Palette.
        </p>
        <div class="reference-command-tools mt-5 grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
          <div class="reference-command-utility-grid">
            <button type="button" class="reference-command-utility" data-site-command-theme>
              <span class="reference-command-utility__label">Darstellung</span>
              <span class="reference-command-utility__value" data-site-command-theme-label>Dark Mode</span>
            </button>
            <button type="button" class="reference-command-utility" data-site-command-contrast>
              <span class="reference-command-utility__label">Erleichterte Bedienung</span>
              <span class="reference-command-utility__value" data-site-command-contrast-label>Aktivieren</span>
            </button>
            <button type="button" class="reference-command-utility" data-site-command-motion>
              <span class="reference-command-utility__label">Bewegung</span>
              <span class="reference-command-utility__value" data-site-command-motion-label>Ausschalten</span>
            </button>
          </div>
          <div class="reference-command-contact">
            <p class="reference-command-contact__label">Kontakt direkt aus dem CMS</p>
            <a href={`mailto:${settings?.data.email}`} class="reference-command-contact__link">{settings?.data.email}</a>
            <a href={footerPhoneHref} class="reference-command-contact__link">{settings?.data.phone}</a>
            <p class="reference-command-contact__address">{settings?.data.address}</p>
          </div>
        </div>
        <div class="mt-5" data-site-command-results></div>
        <p class="reference-command-empty" data-site-command-empty hidden>Keine passenden Einträge gefunden.</p>
      </div>
    </div>

    {!isKeystaticRoute && (
      <div class="cookie-notice" data-cookie-notice hidden>
        <div class="cookie-notice__panel">
          <p class="cookie-notice__eyebrow">Cookie-Hinweis</p>
          <h2 class="cookie-notice__title">Klare Einstellungen für lokale Speicherung und externe Inhalte.</h2>
          <p class="cookie-notice__text">
            Diese Website verwendet notwendige lokale Speicherungen für Darstellung und Bedienung. Externe Inhalte wie Google Maps werden erst nach deiner Zustimmung geladen.
          </p>
          <div class="cookie-notice__actions">
            <button type="button" class="cookie-notice__button cookie-notice__button--secondary" data-cookie-accept-necessary>Nur notwendige</button>
            <button type="button" class="cookie-notice__button cookie-notice__button--primary" data-cookie-accept-external>Externe Inhalte erlauben</button>
          </div>
          <a href={cookiePolicyHref} class="cookie-notice__link">Cookie-Richtlinien lesen</a>
        </div>
      </div>
    )}

    <footer class="bg-slate-800 text-white pt-24 pb-12 mt-20">
      <div class="max-w-7xl mx-auto grid grid-cols-1 gap-16 border-b border-white/10 px-6 pb-20 md:grid-cols-4">
        <div class="col-span-2">
          <div class="mb-6">
            {settings?.data.logo ? (
              <Image
                src={settings.data.logo}
                alt={settings?.data.logoAlt || settings?.data.siteTitle || 'Logo'}
                class="site-logo site-logo--footer h-12 w-auto object-contain"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="font-display text-2xl font-semibold uppercase tracking-[-0.02em]">{settings?.data.siteTitle}</div>
            )}
          </div>
          <p class="text-slate-400 max-w-sm leading-relaxed text-sm">
            {settings?.data.siteDescription}
          </p>
          {socialLinks.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-4 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
              {socialLinks.map((item) => (
                <a href={item.href} target="_blank" rel="noreferrer" class="hover:text-white">{item.label}</a>
              ))}
            </div>
          )}
        </div>
        <div>
          <h4 class="mb-6 text-xs font-mono uppercase text-blue-500">Navigation</h4>
          <ul class="space-y-4 text-sm font-medium">
            {primaryNavLinks.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['footer-nav-link', item.active ? 'footer-nav-link--active text-white' : 'text-slate-300 hover:text-blue-400']}
                  aria-current={item.active ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h4 class="mb-6 text-xs font-mono uppercase text-blue-500">Kontakt</h4>
          <div class="space-y-5 text-sm text-slate-400">
            <p class="whitespace-pre-line">{settings?.data.address}</p>
            <a href={`mailto:${settings?.data.email}`} class="block transition hover:text-white">{settings?.data.email}</a>
            <a href={footerPhoneHref} class="block transition hover:text-white">{settings?.data.phone}</a>
          </div>
        </div>
      </div>
      <div class="max-w-7xl mx-auto flex flex-col gap-6 px-6 pt-12 text-[10px] font-mono uppercase tracking-widest text-slate-500 sm:flex-row sm:items-center sm:justify-between">
        <span>© 2026 Tappauf ZT GmbH</span>
        <div class="flex flex-wrap gap-6">
          {utilityNavLinks.map((item) => (
            <a
              href={item.href}
              class:list={[item.active ? 'text-white' : 'hover:text-white']}
              aria-current={item.active ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </footer>

    <script id="global-command-index" type="application/json" is:inline set:html={globalCommandIndexJson}></script>
    <script is:inline>
      const THEME_STORAGE_KEY = 'tappauf-theme';
      const CONTRAST_STORAGE_KEY = 'tappauf-contrast';
      const MOTION_STORAGE_KEY = 'tappauf-motion';
      const COOKIE_CONSENT_STORAGE_KEY = 'tappauf-cookie-consent';
      const serializedCommandIndex =
        document.getElementById('global-command-index')?.textContent ?? '[]';
      const GLOBAL_COMMAND_INDEX = JSON.parse(serializedCommandIndex);

      const getPreferredTheme = () =>
        window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';

      const getStoredTheme = () => {
        try {
          return localStorage.getItem(THEME_STORAGE_KEY);
        } catch {
          return null;
        }
      };

      const persistTheme = (theme) => {
        try {
          localStorage.setItem(THEME_STORAGE_KEY, theme);
        } catch {}
      };

      const readCookieConsent = () => {
        try {
          const raw = localStorage.getItem(COOKIE_CONSENT_STORAGE_KEY);
          return raw ? JSON.parse(raw) : null;
        } catch {
          return null;
        }
      };

      const writeCookieConsent = (consent) => {
        try {
          localStorage.setItem(COOKIE_CONSENT_STORAGE_KEY, JSON.stringify(consent));
        } catch {}
      };

      const syncExternalEmbeds = (consent = readCookieConsent()) => {
        const externalAllowed = consent?.external === true;

        document.querySelectorAll('[data-external-content]').forEach((container) => {
          const iframe = container.querySelector('[data-external-iframe]');
          const placeholder = container.querySelector('[data-external-placeholder]');
          const src = iframe?.dataset.src;

          if (!iframe || !placeholder || !src) return;

          if (externalAllowed) {
            if (iframe.getAttribute('src') !== src) {
              iframe.setAttribute('src', src);
            }
            iframe.hidden = false;
            placeholder.hidden = true;
          } else {
            iframe.hidden = true;
            placeholder.hidden = false;
            iframe.removeAttribute('src');
          }
        });
      };

      const applyCookieConsent = () => {
        const notice = document.querySelector('[data-cookie-notice]');
        const consent = readCookieConsent();

        if (notice) {
          notice.hidden = Boolean(consent);
        }

        syncExternalEmbeds(consent);
      };

      const setThemeMeta = (theme) => {
        const meta = document.querySelector('meta[name="theme-color"]');
        if (meta) {
          meta.setAttribute('content', theme === 'dark' ? '#020617' : '#f8fafc');
        }
      };

      const applyTheme = (theme) => {
        const root = document.documentElement;
        root.dataset.theme = theme;
        root.classList.toggle('dark', theme === 'dark');
        setThemeMeta(theme);

        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          const label = button.querySelector('.theme-toggle__label');
          if (label) label.textContent = theme === 'dark' ? 'Light' : 'Dark';
          button.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
        });
      };

      const applyAccessibilityPreferences = () => {
        const root = document.documentElement;
        let contrast = null;
        let motion = null;

        try {
          contrast = localStorage.getItem(CONTRAST_STORAGE_KEY);
          motion = localStorage.getItem(MOTION_STORAGE_KEY);
        } catch {}

        root.classList.toggle('high-contrast', contrast === 'high');
        root.classList.toggle('easy-access', contrast === 'high');
        root.classList.toggle('reduced-motion', motion === 'reduce');
        const contrastLabel = document.querySelector('[data-site-command-contrast-label]');
        const motionLabel = document.querySelector('[data-site-command-motion-label]');
        const themeLabel = document.querySelector('[data-site-command-theme-label]');

        if (contrastLabel) {
          contrastLabel.textContent = contrast === 'high' ? 'Aktiv' : 'Aktivieren';
        }

        if (motionLabel) {
          motionLabel.textContent = motion === 'reduce' ? 'Einschalten' : 'Ausschalten';
        }

        if (themeLabel) {
          themeLabel.textContent = root.dataset.theme === 'dark' ? 'Light Mode' : 'Dark Mode';
        }
      };

      const changeTheme = (nextTheme) => {
        persistTheme(nextTheme);
        applyTheme(nextTheme);
      };

      const setupThemeToggle = () => {
        const root = document.documentElement;
        const buttons = document.querySelectorAll('[data-theme-toggle]');
        const media = window.matchMedia('(prefers-color-scheme: dark)');

        applyTheme(getStoredTheme() || root.dataset.theme || getPreferredTheme());

        buttons.forEach((button) => {
          if (button.dataset.themeBound === 'true') return;
          button.dataset.themeBound = 'true';

          button.addEventListener('click', () => {
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            changeTheme(next);
          });
        });

        if (!window.__tappaufThemeMediaBound) {
          media.addEventListener('change', (event) => {
            if (getStoredTheme()) return;
            applyTheme(event.matches ? 'dark' : 'light');
          });
          window.__tappaufThemeMediaBound = true;
        }
      };

      const setupMobileMenu = () => {
        const root = document.documentElement;
        const menu = document.querySelector('[data-mobile-menu]');
        if (!menu || menu.dataset.menuBound === 'true') return;

        const openButtons = document.querySelectorAll('[data-mobile-menu-open]');
        const closeButtons = document.querySelectorAll('[data-mobile-menu-close]');
        const links = document.querySelectorAll('[data-mobile-menu-link]');

        const syncButtons = (expanded) => {
          openButtons.forEach((button) => button.setAttribute('aria-expanded', expanded ? 'true' : 'false'));
        };

        const openMenu = () => {
          menu.hidden = false;
          menu.setAttribute('aria-hidden', 'false');
          root.classList.add('mobile-menu-open');
          syncButtons(true);
        };

        const closeMenu = () => {
          menu.setAttribute('aria-hidden', 'true');
          root.classList.remove('mobile-menu-open');
          syncButtons(false);
          window.setTimeout(() => {
            if (menu.getAttribute('aria-hidden') === 'true') {
              menu.hidden = true;
            }
          }, 260);
        };

        openButtons.forEach((button) => {
          button.addEventListener('click', openMenu);
        });

        closeButtons.forEach((button) => {
          button.addEventListener('click', closeMenu);
        });

        links.forEach((link) => {
          link.addEventListener('click', closeMenu);
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && menu.getAttribute('aria-hidden') === 'false') {
            closeMenu();
          }
        });

        document.addEventListener('astro:before-swap', closeMenu);
        menu.dataset.menuBound = 'true';
      };

      const setupReveal = () => {
        const items = document.querySelectorAll('[data-reveal]');
        if (!items.length || !('IntersectionObserver' in window)) return;

        document.documentElement.classList.add('reveal-enhanced');

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );

        items.forEach((item, index) => {
          item.style.setProperty('--reveal-delay', `${index % 6 * 70}ms`);
          observer.observe(item);
        });
      };

      const setupCookieNotice = () => {
        const notice = document.querySelector('[data-cookie-notice]');
        const acceptNecessaryButtons = document.querySelectorAll('[data-cookie-accept-necessary]');
        const acceptExternalButtons = document.querySelectorAll('[data-cookie-accept-external]');
        const enableExternalButtons = document.querySelectorAll('[data-cookie-enable-external]');

        const saveConsent = (external) => {
          writeCookieConsent({
            necessary: true,
            external,
            updatedAt: new Date().toISOString(),
          });
          if (notice) {
            notice.hidden = true;
          }
          syncExternalEmbeds(readCookieConsent());
        };

        acceptNecessaryButtons.forEach((button) => {
          if (button.dataset.cookieBound === 'true') return;
          button.dataset.cookieBound = 'true';
          button.addEventListener('click', () => saveConsent(false));
        });

        acceptExternalButtons.forEach((button) => {
          if (button.dataset.cookieBound === 'true') return;
          button.dataset.cookieBound = 'true';
          button.addEventListener('click', () => saveConsent(true));
        });

        enableExternalButtons.forEach((button) => {
          if (button.dataset.cookieBound === 'true') return;
          button.dataset.cookieBound = 'true';
          button.addEventListener('click', () => saveConsent(true));
        });

        applyCookieConsent();
      };

      const setupGlobalCommandPalette = () => {
        const dialog = document.querySelector('[data-site-command-dialog]');
        const openButtons = document.querySelectorAll('[data-site-command-open]');
        const closeButton = document.querySelector('[data-site-command-close]');
        const input = document.querySelector('[data-site-command-input]');
        const resultsNode = document.querySelector('[data-site-command-results]');
        const emptyNode = document.querySelector('[data-site-command-empty]');
        const themeButton = document.querySelector('[data-site-command-theme]');
        const contrastButton = document.querySelector('[data-site-command-contrast]');
        const motionButton = document.querySelector('[data-site-command-motion]');

        if (!dialog || !input || !resultsNode || !emptyNode) return;

        let activeIndex = 0;
        const normalize = (value) => (value || '').trim().toLowerCase();

        const renderResults = (value) => {
          const query = normalize(value);
          const tokens = query.split(/\s+/).filter(Boolean);
          if (!tokens.length) {
            resultsNode.innerHTML = '';
            resultsNode.hidden = true;
            emptyNode.hidden = true;
            activeIndex = 0;
            return [];
          }

          const results = GLOBAL_COMMAND_INDEX.filter((entry) => {
            return tokens.every((token) =>
              entry.search.includes(token) ||
              entry.title.toLowerCase().includes(token) ||
              entry.type.toLowerCase().includes(token) ||
              entry.section.toLowerCase().includes(token)
            );
          }).sort((a, b) => {
            const aTitle = a.title.toLowerCase();
            const bTitle = b.title.toLowerCase();
            const aPageBonus = a.type === 'Seite' ? 30 : 0;
            const bPageBonus = b.type === 'Seite' ? 30 : 0;
            const aExact = tokens.some((token) => aTitle === token || aTitle.startsWith(token)) ? 20 : 0;
            const bExact = tokens.some((token) => bTitle === token || bTitle.startsWith(token)) ? 20 : 0;
            const aTitleHits = tokens.filter((token) => aTitle.includes(token)).length;
            const bTitleHits = tokens.filter((token) => bTitle.includes(token)).length;
            const aScore = aPageBonus + aExact + aTitleHits;
            const bScore = bPageBonus + bExact + bTitleHits;
            return bScore - aScore;
          }).slice(0, 10);

          if (!results.length) {
            resultsNode.innerHTML = '';
            resultsNode.hidden = true;
            emptyNode.hidden = false;
            return results;
          }

          resultsNode.innerHTML = results.map((entry, index) => `
            <button
              type="button"
              class="reference-command-result${index === activeIndex ? ' reference-command-result--active' : ''}"
              data-site-command-result
              data-site-command-href="${entry.href}"
            >
              <span class="reference-command-result__title">${entry.title}</span>
              <span class="reference-command-result__meta">${[entry.type, entry.section, entry.description].filter(Boolean).join(' · ')}</span>
            </button>
          `).join('');
          resultsNode.hidden = false;
          emptyNode.hidden = true;
          return results;
        };

        const openDialog = () => {
          dialog.hidden = false;
          dialog.setAttribute('aria-hidden', 'false');
          document.documentElement.classList.add('reference-command-open');
          activeIndex = 0;
          input.value = '';
          resultsNode.innerHTML = '';
          resultsNode.hidden = true;
          emptyNode.hidden = true;
          applyAccessibilityPreferences();
          input.focus();
        };

        window.__tappaufOpenCommandPalette = openDialog;

        const closeDialog = () => {
          dialog.setAttribute('aria-hidden', 'true');
          document.documentElement.classList.remove('reference-command-open');
          window.setTimeout(() => {
            if (dialog.getAttribute('aria-hidden') === 'true') {
              dialog.hidden = true;
            }
          }, 220);
        };

        openButtons.forEach((button) => {
          if (button.dataset.commandBound === 'true') return;
          button.dataset.commandBound = 'true';
          button.addEventListener('click', openDialog);
        });

        if (closeButton && closeButton.dataset.commandBound !== 'true') {
          closeButton.dataset.commandBound = 'true';
          closeButton.addEventListener('click', closeDialog);
        }

        if (dialog.dataset.commandBound === 'true') return;
        dialog.dataset.commandBound = 'true';

        dialog.addEventListener('click', (event) => {
          if (event.target === dialog) closeDialog();
        });

        resultsNode.addEventListener('click', (event) => {
          const target = event.target.closest('[data-site-command-result]');
          if (!target) return;
          const href = target.dataset.siteCommandHref;
          closeDialog();
          if (href) window.location.href = href;
        });

        input.addEventListener('input', () => {
          activeIndex = 0;
          renderResults(input.value);
        });

        input.addEventListener('keydown', (event) => {
          const items = Array.from(resultsNode.querySelectorAll('[data-site-command-result]'));
          if (event.key === 'ArrowDown' && items.length) {
            event.preventDefault();
            activeIndex = (activeIndex + 1) % items.length;
            renderResults(input.value);
          } else if (event.key === 'ArrowUp' && items.length) {
            event.preventDefault();
            activeIndex = (activeIndex - 1 + items.length) % items.length;
            renderResults(input.value);
          } else if (event.key === 'Enter') {
            event.preventDefault();
            items[activeIndex]?.click();
          } else if (event.key === 'Escape') {
            closeDialog();
          }
        });

        themeButton?.addEventListener('click', () => {
          const root = document.documentElement;
          const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
          changeTheme(next);
          window.setTimeout(applyAccessibilityPreferences, 30);
        });

        contrastButton?.addEventListener('click', () => {
          const root = document.documentElement;
          const next = root.classList.contains('high-contrast') ? 'normal' : 'high';
          root.classList.toggle('high-contrast', next === 'high');
          root.classList.toggle('easy-access', next === 'high');
          try {
            localStorage.setItem(CONTRAST_STORAGE_KEY, next === 'high' ? 'high' : 'normal');
          } catch {}
          applyAccessibilityPreferences();
        });

        motionButton?.addEventListener('click', () => {
          const root = document.documentElement;
          const next = root.classList.contains('reduced-motion') ? 'full' : 'reduce';
          root.classList.toggle('reduced-motion', next === 'reduce');
          try {
            localStorage.setItem(MOTION_STORAGE_KEY, next === 'reduce' ? 'reduce' : 'full');
          } catch {}
          applyAccessibilityPreferences();
        });
      };

      const bindGlobalCommandShortcut = () => {
        if (window.__tappaufGlobalCommandHandler) {
          document.removeEventListener('keydown', window.__tappaufGlobalCommandHandler);
        }

        window.__tappaufGlobalCommandHandler = (event) => {
          const dialog = document.querySelector('[data-site-command-dialog]');
          if (!dialog) return;

          if (event.ctrlKey && !event.metaKey && !event.altKey && event.key.toLowerCase() === 'k') {
            event.preventDefault();
            window.__tappaufOpenCommandPalette?.();
          } else if (event.key === 'Escape' && dialog.getAttribute('aria-hidden') === 'false') {
            document.querySelector('[data-site-command-close]')?.click();
          }
        };

        document.addEventListener('keydown', window.__tappaufGlobalCommandHandler);
      };

      setupThemeToggle();
      applyAccessibilityPreferences();
      applyCookieConsent();
      setupMobileMenu();
      setupCookieNotice();
      setupGlobalCommandPalette();
      bindGlobalCommandShortcut();
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(setupReveal, { timeout: 1200 });
      } else {
        window.setTimeout(setupReveal, 120);
      }
      document.addEventListener('astro:page-load', setupThemeToggle);
      document.addEventListener('astro:page-load', applyAccessibilityPreferences);
      document.addEventListener('astro:page-load', applyCookieConsent);
      document.addEventListener('astro:page-load', setupMobileMenu);
      document.addEventListener('astro:page-load', setupCookieNotice);
      document.addEventListener('astro:page-load', setupGlobalCommandPalette);
      document.addEventListener('astro:page-load', bindGlobalCommandShortcut);
      document.addEventListener('astro:page-load', setupReveal);
    </script>
  </body>
</html>
