---
import { Image } from 'astro:assets';

interface TeamEntry {
  data: {
    name: string;
    role: string;
    qualification?: string;
    phone?: string;
    email?: string;
    image?: any;
  };
}

interface Props {
  team: TeamEntry[];
  dark?: boolean;
  roomy?: boolean;
}

const { team, dark = false, roomy = false } = Astro.props;
---

<div class:list={['mt-12 grid', roomy ? 'gap-10 lg:gap-12' : 'gap-8', 'md:grid-cols-2']}>
  {team.map((member) => (
    roomy && !dark ? (
      <article class="overflow-hidden rounded-[2.2rem] border border-slate-200 bg-white shadow-[0_24px_80px_rgba(15,23,42,0.08)]" data-reveal>
        <div class="border-b border-slate-200 px-8 py-8 lg:px-10 lg:py-9">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-blue-600">{member.data.role}</p>
          <h3 class="mt-3 font-display text-[2rem] font-semibold leading-[1.02] tracking-[-0.03em] text-slate-900 lg:text-[2.35rem]">
            {member.data.name}
          </h3>
        </div>

        <div class="grid lg:grid-cols-[0.78fr_1.22fr] lg:items-stretch">
          {member.data.image && (
            <div class="aspect-[4/3] overflow-hidden bg-slate-100 lg:aspect-auto lg:h-full lg:min-h-[22rem]">
              <Image src={member.data.image} alt={member.data.name} class="h-full w-full object-cover" loading="lazy" />
            </div>
          )}

          <div class="p-8 lg:flex lg:flex-col lg:justify-between lg:p-10">
            {member.data.qualification && (
              <p class="max-w-2xl text-base leading-8 text-slate-600">{member.data.qualification}</p>
            )}

            <div class="mt-8 space-y-3 text-base text-slate-700">
              {member.data.phone && <p>{member.data.phone}</p>}
              {member.data.email && <a href={`mailto:${member.data.email}`} class="text-blue-600 hover:text-slate-900">{member.data.email}</a>}
            </div>
          </div>
        </div>
      </article>
    ) : (
      <article class:list={[
        'overflow-hidden rounded-[2rem]',
        dark
          ? 'bg-slate-950 text-white lg:grid lg:grid-cols-[0.82fr_1.18fr]'
          : 'border border-slate-200 bg-white shadow-[0_20px_60px_rgba(15,23,42,0.08)] lg:grid lg:grid-cols-[0.84fr_1.16fr]',
      ]} data-reveal>
        {member.data.image && (
          <div class:list={[
            'overflow-hidden',
            dark
              ? 'aspect-[4/3] bg-slate-900 lg:aspect-auto lg:h-full lg:min-h-[18rem]'
              : 'aspect-[4/3] bg-slate-100 lg:aspect-auto lg:h-full lg:min-h-[19rem]',
          ]}>
            <Image src={member.data.image} alt={member.data.name} class="h-full w-full object-cover" loading="lazy" />
          </div>
        )}
        <div class:list={[
          dark
            ? 'p-7 lg:flex lg:flex-col lg:justify-center lg:p-8'
            : 'p-7 lg:flex lg:flex-col lg:justify-center lg:p-9',
        ]}>
          <p class:list={[
            'text-xs uppercase tracking-[0.24em]',
            dark ? 'text-blue-300' : 'text-blue-600',
          ]}>{member.data.role}</p>
          <h3 class:list={[
            'mt-3 font-semibold tracking-[-0.025em]',
            dark ? 'text-2xl text-white' : 'text-2xl text-slate-900 lg:text-[2rem]',
          ]}>{member.data.name}</h3>
          {member.data.qualification && <p class:list={['text-sm leading-7', dark ? 'mt-5 text-slate-300' : 'mt-5 max-w-xl text-slate-600']}>{member.data.qualification}</p>}
          <div class:list={['text-sm', dark ? 'mt-6 space-y-2 text-slate-300' : 'mt-6 space-y-2 text-slate-700']}>
            {member.data.phone && <p>{member.data.phone}</p>}
            {member.data.email && <a href={`mailto:${member.data.email}`} class:list={[dark ? 'text-blue-300 hover:text-white' : 'text-blue-600 hover:text-slate-900']}>{member.data.email}</a>}
          </div>
        </div>
      </article>
    )
  ))}
</div>
