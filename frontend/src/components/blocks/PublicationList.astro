---
interface PublicationEntry {
  id: string;
  data: {
    title: string;
    year: number;
    citation: string;
    pdfFile?: string;
    pdfUrl?: string;
  };
}

interface Props {
  publications: PublicationEntry[];
  limit?: number;
}

const { publications, limit } = Astro.props;
const items = typeof limit === 'number' ? publications.slice(0, limit) : publications;
---

<div class="mt-12 grid gap-6">
  {items.map((publication) => (
    (() => {
      const pdfHref = publication.data.pdfFile || publication.data.pdfUrl;
      const isLocalPdf = Boolean(publication.data.pdfFile);

      return (
    <article class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-sm" data-reveal>
      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div class="max-w-4xl">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-blue-600">{publication.data.year}</p>
          <h3 class="mt-3 text-2xl font-semibold tracking-[-0.02em] text-slate-950">{publication.data.title}</h3>
          <p class="mt-4 text-sm leading-7 text-slate-600">{publication.data.citation}</p>
        </div>
        {pdfHref && (
          <a
            href={pdfHref}
            target="_blank"
            rel="noreferrer"
            class="inline-flex shrink-0 rounded-full border border-slate-200 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-slate-950 transition hover:border-blue-600 hover:text-blue-600"
          >
            {isLocalPdf ? 'PDF anzeigen' : 'PDF ansehen'}
          </a>
        )}
      </div>
    </article>
      );
    })()
  ))}
</div>
